---
import Layout from "@/layouts/Layout.astro";
import PostItem from "@/components/patterns/PostItem.astro";
import Container from "@/components/primitives/layout/Container.astro";
import { type CollectionEntry, getCollection } from "astro:content";

const allPosts: CollectionEntry<"blog">[] = await getCollection("blog");

const posts: CollectionEntry<"blog">[] = allPosts
  .filter((post) => post.data.status?.toLowerCase() === "publicado")
  .sort((a, b) => {
    const aTime = a.data.pubDate?.getTime() ?? 0;
    const bTime = b.data.pubDate?.getTime() ?? 0;
    return bTime - aTime;
  });
---

<Layout title="Blog" description="Um blog que mostra o poder do Astro nativo!">
  <Container class="pb-30 pt-60 space-y-6">
    <h1>Blog</h1>

    <section class="grid grid-cols-1 gap-5 md:grid-cols-2">
      {
        posts.map((post) => (
          <PostItem
            title={post.data.title}
            slug={`/blog/${post.data.slug}/`}
            cover={post.data.cover}
            pubDate={post.data.pubDate}
            transition:name="listing"
            transition:animate="fade"
          />
        ))
      }
    </section>
  </Container>
</Layout>
