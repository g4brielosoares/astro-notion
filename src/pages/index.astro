---
import Box, { type Variants } from "@/components/patterns/box/Box.astro";
import Slide from "@/components/patterns/Slide.astro";
import Layout from "@/layouts/Layout.astro";
import Accordion from "@/components/patterns/accordion/Accordion.astro";
import AccordionItem from "@/components/patterns/accordion/AccordionItem.astro";

import SlidesData from "@/content/data/home/slides.data.json";
import Container from "@/components/primitives/layout/Container.astro";
import NumberLine from "@/components/patterns/box/NumberLine.astro";

import ComponentDisplay from "@/components/patterns/ComponentDisplay.astro";
import NumberLineRaw from "@/components/patterns/box/NumberLine.astro?raw";
import AstroSvg from "@/components/AstroSvg.astro";
import HausSvg from "@/components/HausSvg.astro";
import Hamburguer from "@/components/Hamburguer.astro";

interface Content {
  title?: string;
  content: string;
  className?: string;
  variant?: Variants;
}
---

<Layout>
  <Container class="space-y-6 md:space-y-10 py-30">
    <Hamburguer />
    <HausSvg />
    <AstroSvg />

    <ComponentDisplay title="NumberLine" code={NumberLineRaw}>
      <NumberLine title="Lorem" index={"01"}>
        <p>
          Lorem ipsum dolor sit amet consectetur adipisicing elit. Veritatis
          nulla dolores qui non. Provident nostrum ipsa magni voluptatibus,
          asperiores laborum non, natus deserunt laudantium enim, perspiciatis
          hic dolorem ipsum ipsam!
        </p>
      </NumberLine>
    </ComponentDisplay>

    <Slide title="O Desafio" indicatorText="Slide 1">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {
          (SlidesData.Slide1 as Content[]).map((caixa) => (
            <Box
              title={caixa.title}
              class={caixa.className}
              variant={caixa.variant}
            >
              <p set:html={caixa.content} />
            </Box>
          ))
        }
      </div>
      <Accordion variant="rounded">
        <AccordionItem title="O que é o Astro?">
          <p>O Astro é um framework web focado em conteúdo e performance.</p>
        </AccordionItem>
        <AccordionItem title="Posso usar componentes dinâmicos?">
          <p class="mb-2">Sim! Veja este componente sendo injetado:</p>
          <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
            {
              (SlidesData.Slide3 as Content[]).map((caixa) => (
                <Box
                  title={caixa.title}
                  class={caixa.className}
                  variant="WhiteHead"
                >
                  <p set:html={caixa.content} />
                </Box>
              ))
            }
          </div>
        </AccordionItem>
        <AccordionItem title="E suporte a imagens?">
          <img
            src="https://picsum.photos/400/200"
            alt="Exemplo"
            class="mt-2 rounded-lg"
          />
        </AccordionItem>
      </Accordion>
    </Slide>

    <Slide title="Por que o Astro é tão Ágil?" indicatorText="Slide 2">
      <ul class="pl-10 space-y-5 text-2xl">
        <li>
          <strong>Filosofia "Zero JavaScript":</strong> O Astro remove todo o código
          pesado e envia apenas HTML puro para o navegador.
        </li>
        <li>
          <strong>Build Estático:</strong> O site é "pré-fabricado" no momento da
          criação. Quando o cliente clica, o site já está pronto, sem precisar "pensar".
        </li>
        <li>
          <strong>Performance Incomparável:</strong> Ideal para Landing Pages (LPs)
          e Sites Institucionais que precisam converter visitantes em segundos.
        </li>
      </ul>
    </Slide>

    <Slide title="SEO: O Melhor Amigo do Google" indicatorText="Slide 3">
      <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
        {
          (SlidesData.Slide3 as Content[]).map((caixa) => (
            <Box
              title={caixa.title}
              class={caixa.className}
              variant="WhiteHead"
            >
              <p set:html={caixa.content} />
            </Box>
          ))
        }
      </div>
    </Slide>

    <Slide
      title="Versatilidade: Use o Melhor de Cada Mundo"
      indicatorText="Slide 4"
    >
      <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
        {
          (SlidesData.Slide4 as Content[]).map((caixa, index) => (
            <Box
              title={caixa.title}
              class={caixa.className}
              variant="NumberCircle"
              index={`${++index}`}
            >
              <p set:html={caixa.content} />
            </Box>
          ))
        }
      </div>
    </Slide>

    <Slide
      title="Roteamento Inteligente"
      indicatorText="Slide 5"
      imageSRC="https://cdn.gamma.app/fzd9z4zd3y750c3/generated-images/obvHNvgKKhPcudzueCY6r.jpg"
      imgSide="right"
    >
      <h5>(Baseado em Arquivos)</h5>
      <div class="grid grid-cols-1 gap-5">
        {
          (SlidesData.Slide5 as Content[]).map((caixa, index) => (
            <Box
              title={caixa.title}
              class={caixa.className}
              variant="NumberLine"
              index={`${index <= 9 && "0"}${++index}`}
            >
              <p set:html={caixa.content} />
            </Box>
          ))
        }
      </div>
    </Slide>

    <Slide
      title="O Segredo: Arquitetura de Ilhas (Islands)"
      indicatorText="Slide 6"
    >
      <div
        class="grid items-center justify-center grid-cols-1 grid-rows-1 gap-5 md:grid-cols-2 md:grid-rows-2 md:grid-flow-col"
      >
        {
          (SlidesData.Slide6 as Content[]).map((caixa) => (
            <Box title={caixa.title} class={caixa.className} variant="Naked">
              <p set:html={caixa.content} />
            </Box>
          ))
        }
      </div>
    </Slide>

    <Slide title="Criação de Páginas Estáticas (Build)" indicatorText="Slide 7">
      <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
        {
          (SlidesData.Slide7 as Content[]).map((caixa) => (
            <Box title={caixa.title} class={caixa.className} variant="Naked">
              <p set:html={caixa.content} />
            </Box>
          ))
        }
      </div>
    </Slide>

    <Slide
      title="Astro vs. WordPress: A Escolha Inteligente para Seu Negócio"
      indicatorText="Slide 8"
    >
      <p>
        Trocar WordPress por Astro é como trocar um carro antigo e pesado, que
        exige manutenção constante, por um veículo de corrida moderno, leve e
        totalmente personalizado.
      </p>
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
        {
          (SlidesData.Slide8 as Content[]).map((caixa, index) => (
            <Box
              title={caixa.title}
              index={`${index <= 9 && "0"}${++index}`}
              variant="NumberLine"
            >
              <p set:html={caixa.content} />
            </Box>
          ))
        }
      </div>
      <div
        class="overflow-x-auto rounded-lg border-2 border-[#4E4855] overscroll-x-none"
      >
        <table>
          <colgroup>
            <col class="w-1/4" />
            <col class="w-1/3" />
            <col class="w-1/3" />
          </colgroup>
          <thead>
            <tr>
              <th scope="col">Critério</th>
              <th scope="col">WordPress</th>
              <th scope="col">Astro</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th scope="row">Velocidade Inicial</th>
              <td>Média/Baixa</td>
              <td>Instantânea</td>
            </tr>
            <tr>
              <th scope="row">Segurança</th>
              <td>Depende de plugins</td>
              <td>Nativa e Alta</td>
            </tr>
            <tr>
              <th scope="row">Liberdade Criativa</th>
              <td>Limitada pelo Tema</td>
              <td>Total e Absoluta</td>
            </tr>
            <tr>
              <th scope="row">Auxílio de IA</th>
              <td>Difícil (menos código e código legado)</td>
              <td>Excelente (código moderno)</td>
            </tr>
            <tr>
              <th scope="row">Custo de Servidor</th>
              <td>R$ 50 - R$ 200/mês</td>
              <td>R$ 0 - R$ 20/mês</td>
            </tr>
          </tbody>
        </table>
      </div>
    </Slide>

    <Slide
      title="Desvendando o Astro: FAQ"
      indicatorText="Perguntas Frequentes"
    >
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
        {
          (SlidesData.SlideFAQ as Content[]).map((caixa, index) => (
            <Box title={caixa.title} index={`${++index}`} variant="WhiteHead">
              <p set:html={caixa.content} />
            </Box>
          ))
        }
      </div>
    </Slide>
  </Container>
</Layout>
