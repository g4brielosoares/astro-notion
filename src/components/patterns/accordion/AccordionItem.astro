---
interface Props {
  title: string;
  className?: string;
}

const { title, className } = Astro.props;
---

<div
  class:list={[
    "group-data-[variant=bottom]/root:not-last:border-b-2",
    "group-data-[variant=rounded]/root:not-last:mb-3 group-data-[variant=rounded]/root:border-2 group-data-[variant=rounded]/root:rounded-lg",
    "accordion-item border-[#4E4855] data-[state=open]:border-white overflow-hidden transition-colors duration-300 group/item",
    className,
  ]}
  data-state="closed"
>
  <button
    type="button"
    class="accordion-trigger flex w-full items-center justify-between p-4 text-left font-medium focus-visible:ring-2 focus-visible:ring-blue-500 outline-none"
  >
    <h3 class="text-xl">{title}</h3>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="w-5 h-5 shrink-0 text-white transition-transform duration-300 rotate-90 group-data-[state=open]/item:rotate-0"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 9l-7 7-7-7"></path>
    </svg>
  </button>

  <div
    class="accordion-content grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 group-data-[state=open]/item:grid-rows-[1fr]"
  >
    <div class="overflow-hidden">
      <div class="p-4 pt-0">
        <slot />
      </div>
    </div>
  </div>
</div>
