---
import HeaderLink from "@/components/primitives/layout/HeaderLink.astro";
import logoP from "@/assets/logo-p.svg";
import { Image } from "astro:assets";

type Link = {
  name: string;
  href: string;
};

const links: Link[] = [
  {
    name: "Sobre",
    href: "/sobre",
  },
  {
    name: "Blog",
    href: "/blog",
  },
];
---

<header class="fixed top-0 w-full p-6 z-999">
  <nav
    class="max-w-200 mx-auto p-4 px-6 bg-[#00000080] backdrop-blur-xl
  rounded-full flex items-center justify-between"
  >
    <a href="/">
      <Image width="20" src={logoP} alt="Logo" />
    </a>
    <div class="space-x-5 md:space-x-7 flex">
      {
        links.map((link) => (
          <HeaderLink href={link.href}>{link.name}</HeaderLink>
        ))
      }
    </div>
  </nav>
</header>
