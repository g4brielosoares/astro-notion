---
interface Props {
  tags: string[];
  class?: string;
}

const { tags, class: className } = Astro.props;
---

{
  tags.length > 0 && (
    <div class:list={["flex flex-wrap justify-center gap-2", className]}>
      {tags.map((tag) => (
        <span
          class="px-3 py-1 rounded-full text-sm border-2 bg-white/10 border-white/20"
          transition:name={tag.toLowerCase().replaceAll(" ", "-") + "-tag"}
        >
          {tag}
        </span>
      ))}
    </div>
  )
}
