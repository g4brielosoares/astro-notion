---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

{
  tags.length > 0 && (
    <div class="flex flex-wrap justify-center gap-2">
      {tags.map((tag) => (
        <span class="px-3 py-1 rounded-full text-sm border-2 bg-white/10 border-white/20">
          {tag}
        </span>
      ))}
    </div>
  )
}
