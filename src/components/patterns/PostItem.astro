---
import FormattedDate from "@/components/primitives/content/FormattedDate.astro";
import placeholder from "@/assets/post-placeholder.png";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  slug: string;
  pubDate: Date;
  cover?: ImageMetadata;
  coverAlt?: string;
}

const {
  title,
  slug,
  pubDate,
  cover = placeholder,
  coverAlt = title,
} = Astro.props;
---

<article
  class="group transition-all duration-400 hover:scale-102 list-none hover:bg-zinc-900 rounded-xl"
>
  <a href={slug}>
    {
      cover && (
        <div class="overflow-hidden rounded-xl aspect-5/3 transition duration-400">
          <Image
            width={480}
            src={cover}
            alt={coverAlt}
            decoding="async"
            loading="lazy"
            format="webp"
            class="scale-105 group-hover:scale-100 transition duration-400 object-cover w-full h-full"
          />
        </div>
      )
    }
    <div class="p-3 md:p-4 space-y-1 md:space-y-2">
      <h4>{title}</h4>
      <p class="text-sm md:text-lg">
        <FormattedDate date={pubDate} />
      </p>
    </div>
  </a>
</article>
