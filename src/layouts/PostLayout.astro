---
import "@/styles/post.css";

import Layout from "./Layout.astro";
import FormattedDate from "@/components/primitives/content/FormattedDate.astro";
import Container from "@/components/primitives/layout/Container.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import placeholder from "@/assets/post-placeholder.png";
import Tags from "@/components/patterns/Tags.astro";

export type Props = {
  title: string;
  slug: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  cover?: ImageMetadata;
  author?: string;
  tags?: string[];
  coverAlt?: string;
};

const {
  title,
  slug,
  pubDate,
  description,
  updatedDate,
  cover = placeholder,
  coverAlt = title,
  author,
  tags = [],
} = Astro.props;
---

<Layout {title} {description}>
  <article class="space-y-6 py-30">
    <figure class="w-19/20 max-w-275 space-y-6! mx-auto">
      {
        cover && (
          <Image
            width={1000}
            src={cover}
            alt={coverAlt}
            decoding="async"
            format="webp"
            class="w-full aspect-video object-cover object-center xl:rounded-xl"
            transition:name={`${slug}-cover`}
          />
        )
      }

      <figcaption
        class="flex flex-col xl:flex-row space-y-1 xl:justify-between max-xl:text-center"
      >
        <div class="space-y-1">
          {
            pubDate && (
              <div>
                Criado em <FormattedDate date={pubDate} />
              </div>
            )
          }
          {
            updatedDate && updatedDate.getDate() !== pubDate.getDate() && (
              <div>
                Atualizado em <FormattedDate date={updatedDate} />
              </div>
            )
          }
        </div>
        {author && <span>Por {author}</span>}
      </figcaption>
    </figure>
    <Container class="space-y-6 max-w-200!">
      <h1 class="text-center" transition:name={`${slug}-title`}>{title}</h1>
      <Tags tags={tags} />
      <slot />
    </Container>
  </article>
</Layout>
