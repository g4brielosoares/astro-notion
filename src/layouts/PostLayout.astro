---
import "@/styles/post.css";

import Layout from "./Layout.astro";
import FormattedDate from "@/components/primitives/content/FormattedDate.astro";
import Container from "@/components/primitives/layout/Container.astro";
import { Image } from "astro:assets";

type Props = {
  title: string;
  description?: string;
  publishedAt: Date;
  lastEditedAt?: Date;
  cover?: ImageMetadata;
  author?: string;
  tags?: string[];
};

const {
  title,
  description,
  publishedAt,
  lastEditedAt,
  cover,
  author,
  tags = [],
} = Astro.props;
---

<Layout {title} {description}>
  <article class="space-y-6 py-30">
    <figure class="w-19/20 max-w-275 space-y-6! mx-auto">
      {
        cover && (
          <Image
            width={1000}
            src={cover}
            alt={title}
            decoding="async"
            format="webp"
            class="w-full aspect-video object-cover object-center xl:rounded-xl"
          />
        )
      }

      <figcaption
        class="flex flex-col xl:flex-row space-y-1 xl:justify-between max-xl:text-center"
      >
        <div class="space-y-1">
          {
            publishedAt && (
              <div>
                Criado em <FormattedDate date={publishedAt} />
              </div>
            )
          }
          {
            lastEditedAt &&
              lastEditedAt.getDate() !== publishedAt.getDate() && (
                <div>
                  Atualizado em <FormattedDate date={lastEditedAt} />
                </div>
              )
          }
        </div>
        {author && <span>Por {author}</span>}
      </figcaption>
    </figure>
    <Container class="space-y-6 max-w-200!">
      <h1 class="text-center">{title}</h1>
      {
        tags.length > 0 && (
          <div class="flex flex-wrap justify-center gap-2">
            {tags.map((tag) => (
              <span class="px-3 py-1 rounded-full text-sm border-2 bg-white/10 border-white/20">
                {tag}
              </span>
            ))}
          </div>
        )
      }
      <slot />
    </Container>
  </article>
</Layout>
